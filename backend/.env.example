# ---- Anthropic ----
# Optional: you can leave this blank and set the key in the app (Admin -> Settings) instead.
# If set here, it acts as a fallback until an admin saves a key in the UI.
ANTHROPIC_API_KEY=

# ---- Security ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=720

# ---- Seeded admin (first startup only) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ---- Models ----
DEFAULT_MODEL=claude-sonnet-5

# ---- Paths (keep OFF OneDrive to avoid sync file-locking) ----
DATA_DIR=C:/ba-agent-data
BA_OUTPUT_DIR=C:/ba-agent-data/BA Output
HOST_STORAGE_DIR=C:/ba-agent-host

# ---- URLs ----
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ---- Email (optional; better to configure this in Admin -> Settings) ----
# These act as a fallback until an admin saves mail settings in the UI.
# If neither is set, approval/set-password links are shown in the admin UI instead.
DEV_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BA Agent <no-reply@example.com>
