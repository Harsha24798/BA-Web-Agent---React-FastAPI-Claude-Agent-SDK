# ---- Claude Code CLI (optional) ----
# Leave blank to auto-detect from PATH / common install locations. Set an explicit
# path only if the backend can't launch `claude` (e.g. uvicorn's PATH misses it).
CLAUDE_CLI_PATH=

# ---- Security ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=720

# ---- Seeded admin (first startup only) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ---- Models ----
DEFAULT_MODEL=claude-sonnet-5

# ---- Paths (keep OFF OneDrive to avoid sync file-locking) ----
DATA_DIR=C:/ba-agent-data
BA_OUTPUT_DIR=C:/ba-agent-data/BA Output
HOST_STORAGE_DIR=C:/ba-agent-host

# ---- URLs ----
APP_BASE_URL=http://localhost:5173
# CORS_ORIGINS: comma-separated allowed frontend origins (scheme://host:port, NO trailing slash).
# Examples:
#   CORS_ORIGINS=http://localhost:5173
#   CORS_ORIGINS=http://localhost:5173,http://192.168.1.50:5173
#   CORS_ORIGINS=http://localhost:5173,https://ba.yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Note: the Anthropic API key and SMTP mail server are configured in the app
# (Admin -> Settings) and stored encrypted in the DB — not here.
