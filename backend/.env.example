# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Security ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=720

# ---- Seeded admin (first startup only) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# ---- Models ----
DEFAULT_MODEL=claude-sonnet-5

# ---- Paths (keep OFF OneDrive to avoid sync file-locking) ----
DATA_DIR=C:/ba-agent-data
BA_OUTPUT_DIR=C:/ba-agent-data/BA Output
HOST_STORAGE_DIR=C:/ba-agent-host

# ---- URLs ----
APP_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ---- Email (optional; if unset, links are logged & shown in the admin UI) ----
DEV_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BA Agent <no-reply@example.com>
