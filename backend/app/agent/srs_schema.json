{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SRS",
  "type": "object",
  "required": ["schema_version", "project", "requirements"],
  "properties": {
    "schema_version": { "type": "string" },
    "srs_id": { "type": "string" },
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "generated_at": { "type": "string" },
        "srs_version": { "type": "integer" }
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "filename": { "type": "string" },
              "content_hash": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        },
        "template_id": { "type": "string" },
        "template_version": { "type": "integer" },
        "model": { "type": "string" },
        "sdk_session_id": { "type": "string" }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "domain": { "type": "string" },
        "modules": { "type": "array", "items": { "type": "string" } },
        "odoo_version": { "type": "string" }
      }
    },
    "overview": { "type": "string" },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "description", "priority"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["functional", "non_functional", "constraint", "assumption"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "priority": { "type": "string", "enum": ["must", "should", "could", "wont"] },
          "odoo_module": { "type": "string" },
          "actors": { "type": "array", "items": { "type": "string" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "document": { "type": "string" },
                "quote": { "type": "string" }
              }
            }
          },
          "status": { "type": "string" }
        }
      }
    },
    "non_functional": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "metric": { "type": "string" }
        }
      }
    },
    "actors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string" }
        }
      }
    },
    "glossary": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": { "type": "string" },
          "definition": { "type": "string" }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "traceability": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "requirement_id": { "type": "string" },
          "source_document": { "type": "string" },
          "confidence": { "type": "number" }
        }
      }
    }
  }
}
